# Backend .env — for running uvicorn directly (without Docker).
# In Docker compose, env comes from the root .env via compose.yml.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://secureshop:secureshop@localhost:5432/secureshop

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth secrets (each at least 32 chars; generate with `openssl rand -base64 48`) ---
JWT_ACCESS_SECRET=replace-me-with-a-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-me-with-a-different-secret-at-least-32-chars
ENCRYPTION_KEY=replace-me-with-an-encryption-key-at-least-32-chars

# --- App ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=INFO
COOKIE_SECURE=false

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Stripe (optional) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
