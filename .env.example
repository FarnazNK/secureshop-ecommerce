# =============================================================================
# Docker Compose environment — copy to .env and fill in real values.
# This file is read by `docker compose up` to populate ${VARS} in compose.yml.
# Never commit a populated .env.
# =============================================================================

# --- Postgres ---
# These create the initial superuser when the postgres container first
# starts. Changing them after the first run requires deleting the
# postgres_data volume.
POSTGRES_USER=secureshop
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=secureshop

# --- Redis ---
# Optional. Leave empty to run without auth (fine for local dev only).
REDIS_PASSWORD=

# --- Auth secrets ---
# Generate each with:  openssl rand -base64 48
# These MUST be different from each other.
JWT_SECRET=replace-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-with-different-openssl-rand-base64-48
COOKIE_SECRET=replace-with-another-openssl-rand-base64-48

# --- CORS ---
# Frontend origin that the backend should accept requests from.
# In compose, the frontend is served by nginx on port 8080.
CORS_ORIGIN=http://localhost:8080

# --- Frontend build args ---
# Where the built bundle should send API requests. `/api` works because
# nginx in the frontend container reverse-proxies that path to the backend.
VITE_API_URL=/api

# --- Stripe (optional in dev) ---
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- SMTP (optional — emails are no-ops without these) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
