# =============================================================================
# Docker Compose environment — copy to .env and fill in real values.
# Compose reads these to populate ${VAR} interpolation in compose.yml.
# Never commit a populated .env.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=secureshop
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=secureshop

# --- Auth secrets (each must be at least 32 chars) ---
# Generate with:  openssl rand -base64 48
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48-result
JWT_REFRESH_SECRET=replace-with-different-openssl-rand-base64-48-result
ENCRYPTION_KEY=replace-with-another-openssl-rand-base64-48-result

# --- Environment ---
NODE_ENV=development
LOG_LEVEL=INFO

# Set to true only when serving over HTTPS in production.
COOKIE_SECURE=false

# --- CORS ---
# Comma-separated. Include the public origin of your frontend.
ALLOWED_ORIGINS=http://localhost:8080

# --- Frontend build args ---
# Where the bundle should send API requests. nginx in the frontend container
# reverse-proxies this path to the backend.
VITE_API_URL=/api/v1

# --- Stripe (optional in dev) ---
# Get test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
